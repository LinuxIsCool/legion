[Unit]
Description=claude-voice arbiter daemon (voice orchestration)
Documentation=file://%h/.claude/plugins/local/legion-plugins/plugins/claude-voice/scripts/voice_arbiter.py
After=pipewire.service wireplumber.service voice-tts.service
Wants=voice-tts.service
Conflicts=voice-queue.service
PartOf=voice.target

[Service]
Type=notify
NotifyAccess=all
WatchdogSec=30
WatchdogSignal=SIGTERM
ExecStart=%h/.local/bin/uv run %h/.claude/plugins/local/legion-plugins/plugins/claude-voice/scripts/voice_arbiter.py
ExecStop=%h/.local/bin/uv run %h/.claude/plugins/local/legion-plugins/plugins/claude-voice/scripts/voice_arbiter.py --stop
WorkingDirectory=%h/.claude/plugins/local/legion-plugins/plugins/claude-voice
Environment=XDG_RUNTIME_DIR=/run/user/1000
Environment=PYTHONUNBUFFERED=1
Restart=on-failure
RestartSec=3

[Install]
WantedBy=voice.target
